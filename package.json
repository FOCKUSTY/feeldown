{
  "name": "feeldown",
  "version": "0.1.0",
  "description": "Социальная платформа для публикации заметок в Markdown с аутентификацией Google OAuth, SSR и Prisma",
  "keywords": [
    "angular",
    "express",
    "prisma",
    "postgresql",
    "markdown",
    "google-oauth",
    "ssr",
    "typescript",
    "blog",
    "social-platform"
  ],
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "ng:build": "ng build",
    "generate": "prisma generate",
    "build": "pnpm run generate && pnpm run ng:build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:feeldown": "node dist/feeldown/server/server.mjs"
  },
  "dependencies": {
    "@angular/common": "^21.2.18",
    "@angular/compiler": "^21.2.18",
    "@angular/core": "^21.2.18",
    "@angular/forms": "^21.2.18",
    "@angular/platform-browser": "^21.2.18",
    "@angular/platform-server": "^21.2.18",
    "@angular/router": "^21.2.18",
    "@angular/ssr": "^21.2.19",
    "@types/express-session": "^1.19.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "fenviee": "^0.1.2",
    "jsonwebtoken": "^9.0.3",
    "ngx-cookie-service": "^22.0.0",
    "ngx-markdown": "^22.0.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "passport-oauth2": "^1.8.0",
    "passport-telegram": "^1.0.0",
    "prismjs": "^1.30.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.19",
    "@angular/cli": "^21.2.19",
    "@angular/compiler-cli": "^21.2.18",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.43",
    "@types/passport-oauth2": "^1.8.0",
    "dotenv": "^17.4.2",
    "jsdom": "^27.4.0",
    "pg": "^8.22.0",
    "postcss": "^8.5.19",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.9.3",
    "vitest": "^4.1.10"
  }
}
