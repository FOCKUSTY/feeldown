generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Auth {
  id           String  @id @default(uuid())
  email        String? @unique

  userId       String  @unique
  providerId   String
  provider     String

  accessToken  String
  refreshToken String?
  token        String
}

model User {
  id           String @id @default(uuid())
  username     String @unique
  name         String

  posts Post[]
}

model Post {
  id      String @id @default(uuid())
  userId  String

  content String

  user    User @relation(fields: [userId], references: [id])
}
